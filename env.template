# ============================================
# E-Course Application Environment Variables
# ============================================
# 
# INSTRUCTIONS:
# 1. Copy this file and rename it to .env
# 2. Fill in your actual values below
# 3. DO NOT commit .env to version control (it's already in .gitignore)
#
# ============================================

# Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name?schema=public
# Example: postgresql://postgres:yourpassword@localhost:5432/e_course?schema=public

DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/e_course?schema=public"

# JWT Secret Key
# Used for signing and verifying authentication tokens
# IMPORTANT: Change this to a random, secure string in production!
# Generate a secure random string (at least 32 characters)
# You can generate one using: openssl rand -base64 32
JWT_SECRET="change-this-to-a-random-secure-string-at-least-32-characters-long"

# ============================================
# Inworld AI TTS API Configuration
# ============================================

# Inworld AI API Key (Base64 encoded credentials)
# Get your credentials from: https://studio.inworld.ai/
# Format: Base64(workspace_id:api_key)
# To generate: echo -n "workspace_id:api_key" | base64
# Example: echo -n "my-workspace-id:my-api-key" | base64
# This provides both audio generation AND word-level timestamps in a single API call

INWORLD_API_KEY="your-base64-encoded-credentials-here"

# OpenAI (admin EN↔RU translation). Required for Translate buttons in admin.
OPENAI_API_KEY="sk-..."
# Optional; default gpt-4o-mini
# OPENAI_TRANSLATE_MODEL="gpt-4o-mini"

# Inworld AI Voice IDs
# The voice IDs to use for different types of audio generation
# You can find available voices in the Inworld AI documentation
# Optional: If not set, will use the default voice IDs below

# EN Voice ID - Used for English introduction/chapter sections and Admin "Generate English audio" bulk job
# Default: Dennis
INWORLD_EN_VOICE_ID="Dennis"

# RU Voice ID - Used for Russian introduction and chapter sections
# Default: Dennis (can be changed to a different voice)
INWORLD_RU_VOICE_ID="Dennis"

# Backward-compatible fallbacks
INWORLD_MAN_VOICE_ID="Dennis"
INWORLD_WOMAN_VOICE_ID="Dennis"

# Inworld AI Model ID
# Options: inworld-tts-1 (faster) or inworld-tts-1-max (higher quality)
# Default: inworld-tts-1
INWORLD_MODEL_ID="inworld-tts-1"

# Inworld AI Temperature
# Controls the randomness/expressiveness of generated speech
# Range: 0.0 to 2.0
# Default: 1.1 (recommended for most stable results)
# Higher values (1.2-2.0) = more random and expressive output
# Lower values (0.0-1.0) = more deterministic and consistent output
# You can also override this per-request in the admin panel
INWORLD_TEMPERATURE="1.1"

# ============================================
# SMTP Email Service Configuration
# ============================================
# Used for: registration alerts, password reset, quiz completion notifications, contact form, email verification

# SMTP microservice endpoint URL
SMTP_SERVER_URL="http://65.21.146.18:8080/send"

# SMTP server hostname
SMTP_SERVER_HOST="mail.floridalistingsrealestate.com"

# SMTP authentication credentials
SMTP_USER="admin@63hours.com"
SMTP_PASS="your-smtp-password"

# From address used for outbound email (verification emails, etc.)
SMTP_FROM="admin@63hours.com"

# Admin and forwarding (for documentation and optional use in app)
# Emails from the app are sent from this address. Replies go to this address.
ADMIN_EMAIL="admin@63hours.com"

# All emails sent TO admin@63hours.com (e.g. replies to verification emails) should be forwarded here.
# Configure this forwarding on your mail server (e.g. mail.floridalistingsrealestate.com / cPanel or your host).
# The application cannot receive email; forwarding is a server-side rule at your email provider.
ADMIN_FORWARD_EMAIL="Broker@FloridaListingsRealEstate.com"

# Where admin notifications should be sent (your email)
ADMIN_NOTIFY_EMAIL="you@example.com"

# Public site URL used for password reset and verification links
SITE_URL="http://localhost:3000"

# ============================================
# Setup Instructions
# ============================================
# 
# 1. DATABASE_URL:
#    - Replace 'postgres' with your PostgreSQL username
#    - Replace 'yourpassword' with your PostgreSQL password
#    - Replace 'localhost' with your database host (if different)
#    - Replace '5432' with your PostgreSQL port (if different)
#    - Replace 'e_course' with your database name
#
# 2. JWT_SECRET:
#    - Generate a secure random string
#    - Use at least 32 characters
#    - Keep this secret! Never commit it to version control
#    - Example command to generate: openssl rand -base64 32
#
# 3. INWORLD_API_KEY:
#    - Sign up at https://studio.inworld.ai/
#    - Get your workspace ID and API key from the dashboard
#    - Encode them as Base64: echo -n "workspace_id:api_key" | base64
#    - Paste the Base64 string here (keep the quotes)
#    - Example: echo -n "my-workspace-id:my-api-key" | base64
#    - This provides both audio AND word-level timestamps in one API call
#
# 4. INWORLD_EN_VOICE_ID:
#    - Optional: Keep the default or change to your preferred English voice
#    - Used for English introduction and chapter sections
#    - Find available voices in Inworld AI documentation
#
# 5. INWORLD_RU_VOICE_ID:
#    - Optional: Keep the default or change to your preferred Russian voice
#    - Used for Russian introduction and chapter sections
#    - Find available voices in Inworld AI documentation
#
# 6. INWORLD_MAN_VOICE_ID / INWORLD_WOMAN_VOICE_ID:
#    - Backward-compatible fallbacks for older code paths
#
# 7. INWORLD_MODEL_ID:
#    - Optional: Choose between "inworld-tts-1" (faster) or "inworld-tts-1-max" (higher quality)
#    - Default: inworld-tts-1
#
# 7. INWORLD_TEMPERATURE:
#    - Optional: Temperature for controlling randomness/expressiveness of generated speech
#    - Range: 0.0 to 2.0
#    - Default: 1.1 (recommended for most stable results)
#    - Higher values (1.2-2.0) = more random and expressive output
#    - Lower values (0.0-1.0) = more deterministic and consistent output
#    - You can also override this per-request in the admin panel
#
# After updating .env file:
# - Restart your development server: npm run dev
# - Run database migrations: npm run db:migrate
# - Seed the database: npm run db:seed
#
# ============================================

